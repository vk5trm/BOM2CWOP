def weather():
    """Returns Standard METAR text metadata with a Date/Time header line"""
    output_lines = []
    
    A = 17.27
    B = 237.7
    station_filter = request.args.get('station', '').strip().lower()

    # --- 1. Generate Date/Time Line (YYYY/MM/DD HH:MM) ---
    # Using local time or UTC depending on preference. 
    # The code below uses UTC to match standard METAR practices.
    now = time.gmtime()
    date_time_str = time.strftime("%Y/%m/%d %H:%M", now)
    
    # Add this as the very first line of output
    output_lines.append(date_time_str)

    # Get current UTC time for the METAR timestamp (internal format)
    metar_time = time.strftime("%d%H%MZ", now)

    for full_id, config in STATION_CONFIG.items():
        parts = full_id.split('.')
        station_product_code = parts[0]
        station_id = parts[-1]
        
        station_name = config.get('name', f"Station {station_id}")
        
        # Filter Logic
        if station_filter:
            if station_filter not in station_name.lower() and station_filter not in station_id.lower():
                continue

        obs, _ = fetch_bom_data(station_id, station_product_code)
        
        if not obs:
            if not station_filter or station_name.lower().startswith(station_filter):
                # Optional: You might want to skip adding "NO DATA" lines to keep it clean,
                # or keep them for debugging.
                pass 
            continue

        # --- Extract Data (Robust Version) ---
        temp_c = obs.get('air_temp')
        humidity = obs.get('rel_hum')
        press_hpa = obs.get('press')
        vis_km = obs.get('vis_km') or obs.get('vis') or obs.get('visibility')
        
        # --- Rain Extraction (Safe) ---
        rain_mm_val = None
        rain_mm_raw = obs.get('rain_trace') or obs.get('rain')
        if rain_mm_raw is not None:
            try:
                rain_mm_val = float(rain_mm_raw)
            except:
                rain_mm_val = None
        
        has_rain = rain_mm_val is not None and rain_mm_val > 0

        # --- Wind Extraction ---
        wind_dir_val = obs.get('wind_dir')
        wind_spd_kmh = obs.get('wind_spd_kmh') or obs.get('wind')
        gust_kmh = obs.get('gust_kmh') or obs.get('gust')

        # --- Cloud Extraction (Handles BOTH flat and list formats) ---
        cloud_str = "SKC"
        cloud_layers = obs.get('cloud_layers')
        cloud_oktas = obs.get('cloud_oktas')
        cloud_base_m = obs.get('cloud_base_m')
        cloud_desc = obs.get('cloud', '')

        metar_amount = "SKC"
        base_ft_final = 0

        # Priority 1: Use cloud_layers if it's a list (Standard BOM format)
        if isinstance(cloud_layers, list) and len(cloud_layers) > 0:
            # Sort by base
            try:
                sorted_layers = sorted(cloud_layers, key=lambda k: k.get('base', 99999))
            except:
                sorted_layers = cloud_layers
            
            # Take the lowest layer (most significant for METAR usually, or combine if needed)
            # For simplicity, we take the most significant (lowest) or first one
            layer = sorted_layers[0]
            amt_raw = layer.get('amount', '').upper()
            base_m = layer.get('base', 0)
            
            # Map amount
            if amt_raw in ['FEW', 'SCT', 'BKN', 'OVC']:
                metar_amount = amt_raw
            elif amt_raw in ['CLEAR', 'SKC', 'NONE']:
                metar_amount = "SKC"
            elif amt_raw == 'OVERCAST':
                metar_amount = "OVC"
            elif amt_raw == 'SCATTERED':
                metar_amount = "SCT"
            elif amt_raw == 'BROKEN':
                metar_amount = "BKN"
            else:
                # Fallback to coverage percent
                pct = layer.get('coverage', layer.get('percent', 0))
                if pct < 5: metar_amount = "SKC"
                elif pct < 25: metar_amount = "FEW"
                elif pct < 50: metar_amount = "SCT"
                elif pct < 90: metar_amount = "BKN"
                else: metar_amount = "OVC"
            
            # Convert base
            if base_m:
                try:
                    base_ft = float(base_m) * 3.28084
                    if base_ft < 100:
                        base_ft_final = 0
                    else:
                        base_ft_final = int(round(base_ft / 100) * 100)
                except:
                    base_ft_final = 0

        # Priority 2: Use flat keys if list is empty/missing
        elif cloud_oktas is not None or cloud_desc:
            oktas = int(cloud_oktas) if cloud_oktas is not None else 0
            
            if oktas > 0:
                if oktas <= 1: metar_amount = "FEW"
                elif oktas <= 3: metar_amount = "SCT"
                elif oktas <= 5: metar_amount = "BKN"
                else: metar_amount = "OVC"
            else:
                # Fallback to text
                desc = cloud_desc.upper()
                if "CLEAR" in desc or "NONE" in desc: metar_amount = "SKC"
                elif "FEW" in desc: metar_amount = "FEW"
                elif "SCATTERED" in desc: metar_amount = "SCT"
                elif "BROKEN" in desc: metar_amount = "BKN"
                elif "OVERCAST" in desc or "CLOUDY" in desc: metar_amount = "OVC"
            
            # Convert base if available
            if cloud_base_m:
                try:
                    base_ft = float(cloud_base_m) * 3.28084
                    if base_ft < 100:
                        base_ft_final = 0
                    else:
                        base_ft_final = int(round(base_ft / 100) * 100)
                except:
                    base_ft_final = 0

        # --- CRITICAL FIX: Rain implies clouds ---
        if has_rain and metar_amount == "SKC":
            # If rain is present but sky is reported clear, force OVC (Overcast)
            # Use a default low base if not provided
            if base_ft_final == 0:
                base_ft_final = 300 # 300ft default for low clouds
            metar_amount = "OVC"

        # --- Construct Cloud String ---
        if metar_amount == "SKC":
            cloud_str = "SKC"
        else:
            # If base is 0 (ground level/obscured), show 000
            # If base is >= 100, show 010, 020, etc.
            if base_ft_final == 0:
                cloud_str = f"{metar_amount}000"
            else:
                cloud_str = f"{metar_amount}{int(base_ft_final/100):03d}"

        # --- Temperature & Dew Point (Crash-Proof Version) ---
        temp_str = "///"
        dew_str = "///"
        A = 17.27
        B = 237.7
        
        # Ensure we have valid numbers before calculating
        if temp_c is not None and humidity is not None:
            try:
                t = float(temp_c)
                rh = float(humidity)
                
                # --- Temperature Formatting ---
                if t < 0:
                    temp_str = f"M{abs(t):02.0f}"
                else:
                    temp_str = f"{t:02.0f}"
                
                # --- Dew Point Calculation (Safe) ---
                # Only calculate if humidity is strictly between 0 and 100
                if 0 < rh < 100:
                    # Avoid division by zero if t is exactly -237.7
                    if (B + t) != 0:
                        alpha = (A * t) / (B + t) + math.log(rh / 100.0)
                        dew_point = (B * alpha) / (A - alpha)
                        
                        if dew_point < 0:
                            dew_str = f"M{abs(dew_point):02.0f}"
                        else:
                            dew_str = f"{dew_point:02.0f}"
                    else:
                        # t is too cold for this formula
                        pass
                # If rh is 0 or 100, we skip calculation and leave dew_str as "///"
                # (Standard METAR practice for extreme humidity or if calculation fails)
                
            except Exception as e:
                # Catch any unexpected math errors and leave as ///
                # Optionally print to console for debugging:
                # print(f"DEBUG: Dew point calc failed: {e}")
                pass
        # --- Pressure ---
        qnh_str = f"Q{int(float(press_hpa))}" if press_hpa else "Q////"

        # --- Visibility ---
        vis_str = "9999"
        if vis_km:
            try:
                vis_val = float(vis_km)
                vis_str = "9999" if vis_val >= 10 else ("0000" if vis_val < 0.1 else f"{int(vis_val * 1000):04d}")
            except:
                pass

        # --- Wind & Gusts ---
        wind_deg = "///"
        wind_kt = "///"
        gust_kt = None

        # 1. Determine Wind Direction (in degrees)
        wind_deg_val = None
        if wind_dir_val:
            if wind_dir_val in cardinal_lookup:
                wind_deg_val = cardinal_lookup[wind_dir_val]
            else:
                try:
                    wind_deg_val = int(float(wind_dir_val))
                except:
                    pass
        
        # 2. Determine Wind Speed (in Knots)
        wind_kt_int = None
        if wind_spd_kmh:
            try:
                val = float(wind_spd_kmh) / 1.852
                wind_kt_int = int(round(val))
            except:
                pass

        # 3. Determine Gusts (in Knots)
        gust_kt_val = None
        if gust_kmh:
            try:
                val = float(gust_kmh) / 1.852
                gust_kt_val = int(round(val))
            except:
                pass

        # 4. Construct Wind String
        # METAR Rule: If speed is 0, wind is CALM -> "00000KT"
        # If speed is > 0, use direction and speed.
        # If data is missing, use "///////"

        if wind_kt_int is not None:
            if wind_kt_int == 0:
                # CALM: Force direction to 000, speed to 00
                wind_str = "00000KT"
            else:
                # Wind exists
                if wind_deg_val is not None:
                    # Format: DDDSSKT or DDDSSGSSKT
                    wind_deg = f"{wind_deg_val:03d}"
                    wind_kt = f"{wind_kt_int:02d}"
                    if gust_kt_val:
                        gust_kt = f"{gust_kt_val:02d}"
                        wind_str = f"{wind_deg}{wind_kt}G{gust_kt}KT"
                    else:
                        wind_str = f"{wind_deg}{wind_kt}KT"
                else:
                    # Speed is > 0 but direction is missing -> Invalid METAR wind
                    wind_str = "///////"
        else:
            # Speed is missing entirely
            wind_str = "///////"
        # --- Weather Phenomena ---
        weather_str = "RA" if has_rain else ""

        # --- Station ID ---
        station_code = station_name.replace(" ", "")[:4].upper() if station_name else f"STN{station_id[-3:]}"

        # --- Construct METAR Line ---
        metar_time = time.strftime("%d%H%MZ", time.gmtime())
        nosig = "NOSIG" if not weather_str else ""
        
        metar_parts = [
            station_code,
            metar_time,
            wind_str,
            vis_str,
            cloud_str,
            f"{temp_str}/{dew_str}",
            qnh_str
        ]
        
        if weather_str:
            metar_parts.append(weather_str)
        if nosig:
            metar_parts.append(nosig)
            
        metar_line = " ".join(metar_parts)
        output_lines.append(metar_line)


    if not output_lines:
        # If no data found, the first line (date/time) was already added
        # We can append a message or just return the date/time
        if len(output_lines) == 1:
            output_lines.append("No data found for the specified station.")
        else:
            output_lines.append("No data found for the specified station.")

    return Response("\n".join(output_lines), mimetype='text/plain; charset=utf-8')

@app.route('/aprs')
def trigger_aprs():
    """Manual trigger for testing"""
    try:
        aprs_client = APRSClient(APRS_CALL, APRS_PASSCODE, host=APRS_SERVER, port=APRS_PORT)
        aprs_client.connect()
        sent_count = 0
        
        for full_id, config in STATION_CONFIG.items():
            parts = full_id.split('.')
            station_product_code = parts[0]
            station_id = parts[-1]
            
            wx_call = config.get('aprs_call', APRS_CALL)
            station_name = config.get('name', f"Station {station_id}")
            
            obs, _ = fetch_bom_data(station_id, station_product_code)
            if obs is None:
                continue
            
            comment = ("%s WX" % station_name) or ("BOMWX %s" % station_id)
            aprs_str = bom_json_to_aprs(obs, comment=comment)
            if not aprs_str:
                continue
            
            aprs_client.send_packet(wx_call, aprs_str)
            sent_count += 1
            time.sleep(0.5)
            
        aprs_client.close()
        return jsonify({"status": "success", "packets_sent": sent_count})
    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500

