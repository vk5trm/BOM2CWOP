@app.route('/weather')
def weather():
    """Returns Standard METAR text metadata (e.g., LFPG 101230Z 22015...)"""
    output_lines = []
    
    A = 17.27
    B = 237.7
    station_filter = request.args.get('station', '').strip().lower()

    # Get current UTC time for the METAR timestamp
    now = time.strftime("%d%H%MZ", time.gmtime())

    for full_id, config in STATION_CONFIG.items():
        parts = full_id.split('.')
        station_product_code = parts[0]
        station_id = parts[-1]
        
        station_name = config.get('name', f"Station {station_id}")
        
        # Filter Logic
        if station_filter:
            if station_filter not in station_name.lower() and station_filter not in station_id.lower():
                continue

        obs, _ = fetch_bom_data(station_id, station_product_code)
        
        if not obs:
            if not station_filter or station_name.lower().startswith(station_filter):
                output_lines.append(f"NO DATA: {station_name} ({station_id})")
                output_lines.append("=" * 40)
            continue

        # --- Extract Data ---
        temp_c = obs.get('air_temp')
        humidity = obs.get('rel_hum')
        press_hpa = obs.get('press')
        vis_km = obs.get('vis_km') or obs.get('vis') or obs.get('visibility')
        cloud_layers = obs.get('cloud_layers')
        wind_dir_val = obs.get('wind_dir')
        wind_spd_kmh = obs.get('wind_spd_kmh') or obs.get('wind')
        gust_kmh = obs.get('gust_kmh') or obs.get('gust')
        rain_mm = obs.get('rain_trace') or obs.get('rain')

        # --- Calculate Dew Point ---
        dew_str = "///"
        if temp_c is not None and humidity is not None:
            try:
                t = float(temp_c)
                rh = float(humidity)
                if 0 < rh <= 100:
                    alpha = (A * t) / (B + t) + math.log(rh / 100.0)
                    dew_point = (B * alpha) / (A - alpha)
                    dew_str = f"M{abs(dew_point):.0f}" if dew_point < 0 else f"{dew_point:.0f}"
            except:
                pass

        # --- Temperature (2 digits, M for minus) ---
        temp_str = "///"
        if temp_c is not None:
            try:
                t_val = float(temp_c)
                if t_val < 0:
                    # Format: M + 2 digits (e.g., M14 for -14C)
                    temp_str = f"M{abs(t_val):02.0f}"
                else:
                    # Format: 2 digits (e.g., 14 for 14C)
                    temp_str = f"{t_val:02.0f}"
            except:
                pass

        # --- Dew Point ---
        dew_str = "///"
        if temp_c is not None and humidity is not None:
            try:
                t = float(temp_c)
                rh = float(humidity)
                if 0 < rh <= 100:
                    alpha = (A * t) / (B + t) + math.log(rh / 100.0)
                    dew_point = (B * alpha) / (A - alpha)
                    if dew_point < 0:
                        # Format: M + 2 digits (e.g., M08 for -8C)
                        dew_str = f"M{abs(dew_point):02.0f}"
                    else:
                        # Format: 2 digits (e.g., 08 for 8C)
                        dew_str = f"{dew_point:02.0f}"
            except:
                pass

        # --- Pressure ---
        qnh_str = f"Q{int(float(press_hpa))}" if press_hpa else "Q////"

        # --- Visibility ---
        vis_str = "9999"
        if vis_km:
            try:
                vis_val = float(vis_km)
                vis_str = "9999" if vis_val >= 10 else ("0000" if vis_val < 0.1 else f"{int(vis_val * 1000):04d}")
            except:
                pass

        # --- Clouds (Default SKC) ---
        cloud_str = "SKC"
        if isinstance(cloud_layers, list) and len(cloud_layers) > 0:
            metar_clouds = []
            try:
                sorted_layers = sorted(cloud_layers, key=lambda k: k.get('base', 99999))
            except:
                sorted_layers = cloud_layers
            
            for layer in sorted_layers[:3]:
                amount = layer.get('amount', '').upper()
                base_ft = layer.get('base', 0)
                
                if amount in ['FEW', 'SCT', 'BKN', 'OVC']:
                    metar_amount = amount
                elif amount in ['CLEAR', 'SKC']:
                    metar_amount = "SKC"
                elif amount == 'OVERCAST':
                    metar_amount = "OVC"
                elif amount == 'SCATTERED':
                    metar_amount = "SCT"
                elif amount == 'BROKEN':
                    metar_amount = "BKN"
                else:
                    pct = layer.get('coverage', layer.get('percent', 0))
                    if pct < 5: metar_amount = "SKC"
                    elif pct < 25: metar_amount = "FEW"
                    elif pct < 50: metar_amount = "SCT"
                    elif pct < 90: metar_amount = "BKN"
                    else: metar_amount = "OVC"
                
                base_val = float(base_ft) if base_ft else 0
                if base_val < 100 and base_val > 0: 
                    base_ft_final = int(base_val * 3.28084)
                else:
                    base_ft_final = int(base_val)
                
                if base_ft_final < 100: base_ft_final = 0
                else: base_ft_final = int(base_ft_final / 100) * 100
                
                cloud_entry = f"{metar_amount}{int(base_ft_final/100):03d}" if base_ft_final > 0 else f"{metar_amount}///"
                metar_clouds.append(cloud_entry)
            
            if metar_clouds:
                cloud_str = " ".join(metar_clouds)

        # --- Wind & Gusts ---
        # Direction is 3 digits (e.g., 067)
        wind_deg = "///"
        if wind_dir_val in cardinal_lookup:
            wind_deg = f"{cardinal_lookup[wind_dir_val]:03d}"
        else:
            try:
                wind_deg = f"{int(float(wind_dir_val)):03d}"
            except:
                pass
        
        # Speed and Gust are 2 digits (e.g., 12 or 10)
        wind_kt = "///"
        if wind_spd_kmh:
            try:
                wind_kt = f"{int(float(wind_spd_kmh) / 1.852):02d}"
            except:
                pass
        
        gust_kt = None
        if gust_kmh:
            try:
                gust_kt = f"{int(float(gust_kmh) / 1.852):02d}"
            except:
                pass
        
        wind_str = "///////"
        if wind_deg != "///" and wind_kt != "///":
            if gust_kt:
                wind_str = f"{wind_deg}{wind_kt}G{gust_kt}KT"
            else:
                wind_str = f"{wind_deg}{wind_kt}KT"
        # --- Weather Phenomena ---
        weather_str = "RA" if rain_mm and float(rain_mm) > 0 else ""

        # --- Station ID ---
        station_code = station_name.replace(" ", "")[:4].upper() if station_name else f"STN{station_id[-3:]}"

        # --- Construct Standard METAR Line ---
        # Format: STNID TIME WIND VIS CLOUDS TEMP/DEW QNH [WEATHER] [NOSIG]
        # Example: LFPG 101230Z 22015G25KT 9999 FEW040 24/15 Q1018 NOSIG
        
        nosig = "NOSIG" if not weather_str else "" # Add NOSIG if no rain/storm
        
        # Build the string
        metar_parts = [
            station_code,
            now,
            wind_str,
            vis_str,
            cloud_str,
            f"{temp_str}/{dew_str}",
            qnh_str
        ]
        
        if weather_str:
            metar_parts.append(weather_str)
        if nosig:
            metar_parts.append(nosig)
            
        metar_line = " ".join(metar_parts)
        
        # Add raw details
        dew_info = f"{dew_str}C" if dew_str != "///" else "N/A"
        gust_info = f"G{gust_kmh}kmh" if gust_kmh else ""
        cloud_info = cloud_str if cloud_str != "SKC" else "Clear"
        
        output_lines.append(metar_line)
#        output_lines.append(f"  Details: {station_name} | Temp: {temp_c}C | DewPt: {dew_info} | Wind: {wind_spd_kmh}kmh{gust_info}/{wind_deg} | QNH: {press_hpa}hPa | Vis: {vis_km}km | Cloud: {cloud_info} | Rain: {rain_mm}mm")
#        output_lines.append("-" * 40)

    if not output_lines:
        output_lines.append("No data found for the specified station.")
        output_lines.append(f"Try: /weather?station=Adelaide")

    return Response("\n".join(output_lines), mimetype='text/plain; charset=utf-8')

@app.route('/aprs')
def trigger_aprs():
    """Manual trigger for testing"""
    try:
        aprs_client = APRSClient(APRS_CALL, APRS_PASSCODE, host=APRS_SERVER, port=APRS_PORT)
        aprs_client.connect()
        sent_count = 0
        
        for full_id, config in STATION_CONFIG.items():
            parts = full_id.split('.')
            station_product_code = parts[0]
            station_id = parts[-1]
            
            wx_call = config.get('aprs_call', APRS_CALL)
            station_name = config.get('name', f"Station {station_id}")
            
            obs, _ = fetch_bom_data(station_id, station_product_code)
            if obs is None:
                continue
            
            comment = ("%s WX" % station_name) or ("BOMWX %s" % station_id)
            aprs_str = bom_json_to_aprs(obs, comment=comment)
            if not aprs_str:
                continue
            
            aprs_client.send_packet(wx_call, aprs_str)
            sent_count += 1
            time.sleep(0.5)
            
        aprs_client.close()
        return jsonify({"status": "success", "packets_sent": sent_count})
    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500

