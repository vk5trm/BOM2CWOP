# --- APRS Logic ---

class APRSClient:
    def __init__(self, user, passwd, host=APRS_SERVER, port=APRS_PORT, timeout=10):
        self.user = user
        self.passwd = passwd
        self.host = host
        self.port = port
        self.sock = None
        self.timeout = timeout

    def connect(self):
        if self.sock:
            return
        s = socket(AF_INET, SOCK_STREAM)
        s.settimeout(self.timeout)
        try:
            s.connect((self.host, self.port))
            login_msg = f'user {self.user} pass {self.passwd} vers BOMWX_HTTP 0.1\n'
            s.send(login_msg.encode())
            self.sock = s
            print(f"[APRS] Connected to {self.host}:{self.port} as {self.user}")
        except Exception as e:
            print(f"[APRS] Failed to connect: {e}")
            raise e

    def send_packet(self, wx_call, data):
        if self.sock is None:
            self.connect()
        packet = f'{wx_call}>APRS:{data}\n'
        self.sock.send(packet.encode())

    def close(self):
        if self.sock:
            try:
                self.sock.shutdown(0)
            except:
                pass
            try:
                self.sock.close()
            except:
                pass
            self.sock = None

def str_or_dots(number, length):
    if number is None:
        return '0' * length
    try:
        if isinstance(number, float):
            return f'%0{length}.0f' % round(number)
        else:
            return f'%0{length}d' % int(number)
    except:
        return '.' * length

def make_aprs_wx(lat_str, lon_str, comment="BOMWX", wind_dir=None, wind_speed=None, wind_gust=None,
                 temperature=None, rain_since_midnight=None, humidity=None, pressure=None):
    return '!%s/%s_%s/%sg%st%sP%sh%sb%s%s' % (
        lat_str, lon_str,
        str_or_dots(wind_dir, 3),
        str_or_dots(wind_speed, 3),
        str_or_dots(wind_gust, 3),
        str_or_dots(temperature, 3),
        str_or_dots(rain_since_midnight, 3),
        str_or_dots(humidity, 2),
        str_or_dots(pressure, 5),
        comment
    )

cardinal_lookup = {
    'N': 0, 'NNE': 22, 'NE': 45, 'ENE': 67, 'E': 90, 'ESE': 112, 'SE': 135, 'SSE': 157,
    'S': 180, 'SSW': 202, 'SW': 225, 'WSW': 247, 'W': 270, 'WNW': 292, 'NW': 315, 'NNW': 337, 'CALM': 0
}

def bom_json_to_aprs(obs, comment="BOMWX"):
    if obs is None:
        return None

    try:
        lat = float(obs.get("lat", 0.0))
        lat_degree = abs(int(lat))
        lat_minute = abs(lat - int(lat)) * 60.0
        lat_min_str = ("%02.2f" % lat_minute).zfill(5)
        lat_dir = "N" if lat > 0 else "S"
        lat_str = "%02d%s" % (lat_degree, lat_min_str) + lat_dir
    except:
        return None

    try:
        lon = float(obs.get("lon", 0.0))
        lon_degree = abs(int(lon))
        lon_minute = abs(lon - int(lon)) * 60.0
        lon_min_str = ("%02.2f" % lon_minute).zfill(5)
        lon_dir = "W" if lon < 0 else "E"
        lon_str = "%03d%s" % (lon_degree, lon_min_str) + lon_dir
    except:
        return None

    try:
        temp_f = float(obs.get('air_temp')) * (9.0 / 5.0) + 32
    except:
        temp_f = None
    try:
        press_hpa = int(float(obs.get('press')) * 10)
    except:
        press_hpa = None
    try:
        if 'calculated_rain_midnight' in obs:
            rain_mm = float(obs['calculated_rain_midnight'])
        else:
            rain_mm = float(obs.get('rain_trace', 0.0))
        rain_in = rain_mm * 0.0393700787
    except:
        rain_in = None
    try:
        humidity = float(obs.get('rel_hum'))
    except:
        humidity = None

    try:
        spd_val = obs.get('wind_spd_kt') or (obs.get('wind_spd_kmh') / 1.852) or (obs.get('wind_spd_ms') * 1.94384)
        wind_speed = float(spd_val)
    except:
        wind_speed = None

    try:
        gust_val = obs.get('gust_kt') or (obs.get('gust_kmh') / 1.852) or (obs.get('gust_ms') * 1.94384)
        wind_gust = float(gust_val)
    except:
        wind_gust = None

    wind_dir_value = obs.get('wind_dir')
    if wind_dir_value in cardinal_lookup:
        wind_dir = cardinal_lookup[wind_dir_value]
    else:
        try:
            wind_dir = int(float(wind_dir_value))
        except:
            wind_dir = None

    return make_aprs_wx(lat_str, lon_str, comment=comment, temperature=temp_f, pressure=press_hpa,
                        rain_since_midnight=rain_in, humidity=humidity, wind_speed=wind_speed,
                        wind_gust=wind_gust, wind_dir=wind_dir)
def fetch_bom_data(station_id, product_code):
    url = BOM_BASE_URL.format(product_code=product_code, station_id=station_id)
    try:
        session = requests.Session()
        session.headers.update(HTTP_HEADERS)
        response = session.get(url, timeout=10)
        if response.status_code != 200:
            return None, None
        
        data = response.json()
        observations_list = []
        
        if 'observations' in data:
            if isinstance(data['observations'], dict) and 'data' in data['observations']:
                observations_list = data['observations']['data']
            elif isinstance(data['observations'], list):
                observations_list = data['observations']
        elif 'data' in data and isinstance(data['data'], list):
            observations_list = data['data']

        if not observations_list:
            return None, None

        latest_obs = observations_list[0]
        current_rain = float(latest_obs.get('rain_trace', 0.0))
        station_name = latest_obs.get('name') or latest_obs.get('station_name') or f"Station {station_id}"
        
        # --- CALCULATE RAIN SINCE MIDNIGHT ---
        rain_since_midnight = current_rain  # Default fallback
        
        current_time_str = latest_obs.get('local_date_time_full')
        if not current_time_str or len(current_time_str) < 10:
            latest_obs['calculated_rain_midnight'] = rain_since_midnight
            return latest_obs, station_name
            
        try:
            current_day = int(current_time_str[6:8])
            current_hour = int(current_time_str[8:10])
            current_year = int(current_time_str[0:4])
        except:
            latest_obs['calculated_rain_midnight'] = rain_since_midnight
            return latest_obs, station_name

        # Find specific historical readings for TODAY
        obs_0000_today = None
        obs_0900_today = None  # The reading at 09:00 (which should have the pre-reset total)
        
        for obs in observations_list:
            time_str = obs.get('local_date_time_full')
            if not time_str or len(time_str) < 10:
                continue
            try:
                obs_day = int(time_str[6:8])
                obs_hour = int(time_str[8:10])
                obs_year = int(time_str[0:4])
                
                if obs_year == current_year and obs_day == current_day:
                    if obs_hour == 0:
                        obs_0000_today = obs
                    elif obs_hour == 9:
                        obs_0900_today = obs
            except:
                continue

        if current_hour >= 9:
            # AFTER 9am (or exactly at 9am)
            # We need (Rain at 09:00 - Rain at 00:00) + Current Rain
            # Note: If current_hour is 9, current_rain might be 0 (if reset happened) or the total (if 09:00 is the last entry).
            # If 09:00 entry has a value > 0, that is the "pre-reset" total.
            
            if obs_0900_today and obs_0000_today:
                try:
                    rain_0900 = float(obs_0900_today.get('rain_trace', 0.0))
                    rain_0000 = float(obs_0000_today.get('rain_trace', 0.0))
                    
                    # If the 09:00 reading is 0, it means the reset happened before this entry was saved.
                    # In that case, we need the 08:30 reading. But based on your info, 09:00 has the value.
                    # If rain_0900 is 0, we might need to fallback to 08:30.
                    if rain_0900 == 0.0:
                        # Fallback: Find 08:30
                        for obs in observations_list:
                            t = obs.get('local_date_time_full')
                            if t and len(t) >= 10:
                                h = int(t[8:10])
                                m = int(t[10:12])
                                if h == 8 and m == 30:
                                    rain_0900 = float(obs.get('rain_trace', 0.0))
                                    break
                    
                    rain_00_to_09 = rain_0900 - rain_0000
                    rain_since_midnight = rain_00_to_09 + current_rain
                except:
                    pass
        else:
            # BEFORE 9am
            # Rain Since Midnight = Current Rain - Rain at 00:00
            if obs_0000_today:
                try:
                    rain_0000 = float(obs_0000_today.get('rain_trace', 0.0))
                    rain_since_midnight = current_rain - rain_0000
                except:
                    pass
        
        # Ensure non-negative
        if rain_since_midnight < 0:
            rain_since_midnight = 0.0
            
        latest_obs['calculated_rain_midnight'] = rain_since_midnight

        return latest_obs, station_name

    except Exception as e:
        print(f"[Fetch] Error for {station_id}: {e}")
        return None, None

def upload_to_aprs():
    """Runs in background thread to upload data every 15 minutes using Global APRS_CALL for login"""
    print(f"[Scheduler] Starting automatic upload loop (every {SCHEDULE_INTERVAL_MINUTES} mins)")
    
    while True:
        try:
            print(f"[Scheduler] Fetching data at {time.strftime('%Y-%m-%d %H:%M:%S')}")
            aprs_client = APRSClient(APRS_CALL, APRS_PASSCODE, host=APRS_SERVER, port=APRS_PORT)
            sent_count = 0
            
            try:
                aprs_client.connect()
                
                for full_id, config in STATION_CONFIG.items():
                    parts = full_id.split('.')
                    station_product_code = parts[0]
                    station_id = parts[-1]
                    
                    # Get name and call for display/log
                    station_name = config.get('name', f"Station {station_id}")
                    wx_call = config.get('aprs_call', APRS_CALL)
                    
                    obs, _ = fetch_bom_data(station_id, station_product_code)
                    
                    if obs is None:
                        print(f"[Scheduler] Failed to fetch data for {station_name}")
                        continue
                    
                    comment = ("%s WX" % station_name) or ("BOMWX %s" % station_id)
                    aprs_str = bom_json_to_aprs(obs, comment=comment)
                    
                    if not aprs_str:
                        print(f"[Scheduler] Failed to format APRS for {station_name}")
                        continue
                    
                    # Send packet using the station's specific call sign
                    # (The connection is logged in as global APRS_CALL)
                    print(f"[Scheduler] Sending packet for {wx_call} ({station_name})")
                    aprs_client.send_packet(wx_call, aprs_str)
                    sent_count += 1
                    time.sleep(0.5) 
                
                print(f"[Scheduler] Upload complete. Packets sent: {sent_count}")
                
            finally:
                aprs_client.close()
        
        except Exception as e:
            print(f"[Scheduler] Critical error in loop: {e}")
        
        time.sleep(SCHEDULE_INTERVAL_SECONDS)

